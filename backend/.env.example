# Core paths — adjust to your local setup
HEPHAESTUS_LOOP_HOME=<YOUR_PATH>/hephaestus-autonomous-loop
HEPHAESTUS_REPO=<YOUR_PATH>/your-target-repo
HEPHAESTUS_DASHBOARD_PORT=8766
HEPHAESTUS_DASHBOARD_HOST=127.0.0.1

# Authentication (optional — if unset, no auth)
HEPHAESTUS_DASHBOARD_PASSWORD=
HEPHAESTUS_BRANCH_PREFIX=auto
HEPHAESTUS_BASE_BRANCH=main
HEPHAESTUS_REMOTE=origin

# Agent configuration
HEPHAESTUS_PRIMARY_AGENT=sisyphus
HEPHAESTUS_FALLBACK_AGENT=atlas
HEPHAESTUS_PRIMARY_MODEL=
HEPHAESTUS_FALLBACK_MODEL=
HEPHAESTUS_USE_MODELS=off

# Review settings
HEPHAESTUS_TIER_REVIEW=on
HEPHAESTUS_TIER1_AGENTS=oracle librarian explore prometheus metis momus
HEPHAESTUS_TIER2_AGENTS=multimodal-looker atlas
HEPHAESTUS_FINAL_AGENT=sisyphus-junior
HEPHAESTUS_TIER1_APPROVE_THRESHOLD=5
HEPHAESTUS_TIER2_APPROVE_THRESHOLD=2

# Loop limits
HEPHAESTUS_MAX_ITER=50
HEPHAESTUS_ITER_TIMEOUT_SEC=2400
HEPHAESTUS_MAX_CONSEC_FAIL=4
HEPHAESTUS_INTER_ITER_SLEEP=10

# Operations
HEPHAESTUS_AUTOPUSH=off
HEPHAESTUS_REVIEW_TIMEOUT_SEC=120
HEPHAESTUS_REVIEW_DIFF_CAP=10000
HEPHAESTUS_RUN_TESTS=on
HEPHAESTUS_RUN_LINT=on
HEPHAESTUS_RUN_TYPECHECK=on
HEPHAESTUS_VERIFY_TIMEOUT_SEC=300

# Scan settings
HEPHAESTUS_SCAN_SCANNERS=6
HEPHAESTUS_SCAN_REVIEWERS=2
HEPHAESTUS_SCAN_SCOPE=apps packages services
HEPHAESTUS_SCANNER_AGENTS=
HEPHAESTUS_REDUCER_AGENTS=
HEPHAESTUS_KEEP_ITERS=20
SCANNERS=
REVIEWERS=
SCOPE=

# Reliability (Phase 2)
# Iteration auto-retention: prune iter dirs older than N days (0 = disabled)
HEPHAESTUS_KEEP_ITERS_DAYS=30
# Always keep at least N most recent iter dirs regardless of age
HEPHAESTUS_KEEP_ITERS_MIN=20
# Warn in health endpoint when free disk drops below N GB
HEPHAESTUS_DISK_WARN_GB=1
# Number of rotated state backups to keep (.bak.1, .bak.2, ...)
HEPHAESTUS_BACKUP_KEEP=5

# Phase 4: Provider rate limiting (MODEL-001)
# Max API calls per provider per minute (0 = disabled)
HEPHAESTUS_RATE_LIMIT_PER_MIN=0
# Max seconds to wait for a rate-limit slot (0 = fail immediately)
HEPHAESTUS_RATE_LIMIT_MAX_WAIT_SEC=5

# FEAT-002: optional notifications on task done/failed (empty = off).
# Any URL that accepts a POST works; ntfy.sh is the recommended self-hosted target,
# e.g. https://ntfy.sh/your-topic — the message is the POST body, Title/Tags are headers.
HEPHAESTUS_NOTIFY_URL=
